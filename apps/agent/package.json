{
  "name": "@restaurant-ai/agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "if [ -f ../../.env ]; then set -a; . ../../.env; set +a; fi; tsx watch src/index.ts dev",
    "build": "tsc -p tsconfig.json",
